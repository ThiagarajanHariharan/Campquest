# ============================================================
# CampusQuest Go - .gitignore
# ============================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# Environment files (NEVER commit secrets!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
build/
dist/
coverage/
*.tgz

# Docker
.docker/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.iml

# Logs
logs/
*.log

# Database backups (don't commit backups)
backups/
*.sql.gz
*.dump

# Ansible sensitive files
ansible/inventory/production/
*vault-password*
*.vault
